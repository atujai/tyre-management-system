generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id          String    @id @default(cuid())
  email       String    @unique
  password    String
  name        String    @unique
  role        Role      @default(STAFF)
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  permissions Json?     @default("{\"tyres\": true, \"users\": false, \"history\": true, \"stepney\": true, \"vehicles\": true, \"allotment\": true, \"dashboard\": true, \"locations\": true, \"documents\": true}")
  history     History[]

  @@map("users")
}

model Make {
  id        String    @id @default(cuid())
  name      String    @unique
  createdAt DateTime  @default(now())
  vehicles  Vehicle[]

  @@map("makes")
}

model VehicleType {
  id        String    @id @default(cuid())
  name      String    @unique
  createdAt DateTime  @default(now())
  vehicles  Vehicle[]

  @@map("vehicle_types")
}

model Vehicle {
  id           String       @id @default(cuid())
  reg          String       @unique
  type         String
  model        String
  stepneySlots Int          @default(1)
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  makeId       String?
  typeId       String?
  axles        Axle[]
  history      History[]
  stepneys     Tyre[]       @relation("VehicleStepneys")
  tyres        Tyre[]
  make         Make?        @relation(fields: [makeId], references: [id])
  vehicleType  VehicleType? @relation(fields: [typeId], references: [id])
  challans     Challan[]
  documents    VehicleDocument[]

  @@map("vehicles")
}

model Axle {
  id        String  @id @default(cuid())
  vehicleId String
  tyreCount Int
  steering  Boolean @default(false)
  drive     Boolean @default(false)
  line      Int?
  sortOrder Int     @default(0)
  vehicle   Vehicle @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  tyres     Tyre[]

  @@map("axles")
}

model Tyre {
  id               String       @id @default(cuid())
  serial           String       @unique
  brand            String
  size             String
  pattern          String?
  purchaseDate     DateTime?
  initialTread     Float        @default(20)
  currentTread     Float        @default(20)
  status           TyreStatus   @default(INVENTORY)
  cost             Float?
  remarks          String?
  withRim          Boolean      @default(true)
  vehicleId        String?
  axleId           String?
  position         String?
  mountingDate     DateTime?
  stepneyVehicleId String?
  stepneyDate      DateTime?
  stepneyType      StepneyType?
  locationId       String?
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt
  history          History[]
  images           TyreImage[]
  axle             Axle?        @relation(fields: [axleId], references: [id])
  location         Location?    @relation(fields: [locationId], references: [id])
  stepneyVehicle   Vehicle?     @relation("VehicleStepneys", fields: [stepneyVehicleId], references: [id])
  vehicle          Vehicle?     @relation(fields: [vehicleId], references: [id])

  @@map("tyres")
}

model TyreImage {
  id        String    @id @default(cuid())
  tyreId    String
  url       String
  type      ImageType @default(TYRE)
  caption   String?
  createdAt DateTime  @default(now())
  tyre      Tyre      @relation(fields: [tyreId], references: [id], onDelete: Cascade)

  @@map("tyre_images")
}

model Location {
  id        String       @id @default(cuid())
  name      String
  type      LocationType
  address   String?
  contact   String?
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt
  tyres     Tyre[]

  @@map("locations")
}

model History {
  id        String   @id @default(cuid())
  date      DateTime @default(now())
  action    String
  details   String?
  tyreId    String
  vehicleId String?
  axleIndex Int?
  position  String?
  userId    String?
  createdAt DateTime @default(now())
  tyre      Tyre     @relation(fields: [tyreId], references: [id], onDelete: Cascade)
  user      User?    @relation(fields: [userId], references: [id])
  vehicle   Vehicle? @relation(fields: [vehicleId], references: [id])

  @@map("history")
}

model Challan {
  id                String          @id @default(cuid())
  vehicleId         String
  challanNumber     String          @unique
  challanDate       DateTime
  offence           String
  section           String?
  fineAmount        Float
  penaltyAmount     Float?
  totalAmount       Float
  status            ChallanStatus   @default(PENDING)
  paymentDate       DateTime?
  paymentReceipt    String?
  paymentMethod     PaymentMethod?
  paymentGatewayRef String?
  location          String?
  evidenceUrl       String?
  source            ChallanSource   @default(MANUAL)
  checkedAt         DateTime        @default(now())
  notes             String?
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  vehicle   Vehicle          @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  payments  ChallanPayment[]

  @@map("challans")
}

model ChallanPayment {
  id            String        @id @default(cuid())
  challanId     String
  amount        Float
  method        PaymentMethod
  gatewayRef    String?
  status        PaymentStatus @default(PENDING)
  initiatedAt   DateTime      @default(now())
  completedAt   DateTime?
  failureReason String?
  receiptUrl    String?

  challan Challan @relation(fields: [challanId], references: [id], onDelete: Cascade)

  @@map("challan_payments")
}

// ============================================
// VEHICLE DOCUMENTS (Enhanced with Reminders)
// ============================================
model VehicleDocument {
  id          String         @id @default(cuid())
  vehicleId   String
  type        DocumentType
  number      String?
  issuer      String?
  issueDate   DateTime?
  expiryDate  DateTime?
  amount      Float?
  status      DocumentStatus @default(ACTIVE)
  fileUrl     String?
  notes       String?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  // Relations
  vehicle     Vehicle        @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  reminders   DocumentReminder[]

  @@map("vehicle_documents")
}

// NEW: Document Reminders
model DocumentReminder {
  id          String   @id @default(cuid())
  documentId  String
  document    VehicleDocument @relation(fields: [documentId], references: [id], onDelete: Cascade)

  type        ReminderType
  daysBefore  Int
  sentAt      DateTime?
  message     String?

  createdAt   DateTime @default(now())

  @@index([documentId])
  @@index([sentAt])
  @@map("document_reminders")
}

enum Role {
  ADMIN
  STAFF
}

enum TyreStatus {
  MOUNTED
  INVENTORY
  STEPNEY
  WORN
  DAMAGED
  REPAIR
  SCRAPPED
}

enum StepneyType {
  READY
  BURST
  CLAIM
  PUNCTURE
  RETREAD_CHECKUP
}

enum LocationType {
  GODOWN
  RETREADER
}

enum ImageType {
  TYRE
  DOCUMENT
  SERIAL_NUMBER
}

enum ChallanStatus {
  PENDING
  PAID
  DISMISSED
  CONTESTED
  OVERDUE
  PAYMENT_FAILED
}

enum PaymentMethod {
  ONLINE
  UPI
  CARD
  NETBANKING
  WALLET
  CASH
}

enum PaymentStatus {
  PENDING
  SUCCESS
  FAILED
  REFUNDED
}

enum ChallanSource {
  PARIVAHAN
  STATE_RTO
  MANUAL
  IMPORT
}

// ============================================
// DOCUMENT TYPES (Enhanced)
// ============================================
enum DocumentType {
  RC
  INSURANCE
  PUC
  FITNESS
  PERMIT
  ROAD_TAX
  NOC
  LICENSE        // NEW
  TAX            // NEW
  OTHER
}

// ============================================
// DOCUMENT STATUSES (Enhanced)
// ============================================
enum DocumentStatus {
  ACTIVE
  EXPIRING_SOON
  EXPIRED
  UNDER_RENEWAL
  RENEWAL_PENDING  // NEW
  PENDING
  ARCHIVED         // NEW
}

// ============================================
// NEW: Reminder Types
// ============================================
enum ReminderType {
  EXPIRY_30_DAYS
  EXPIRY_15_DAYS
  EXPIRY_7_DAYS
  EXPIRY_1_DAY
  EXPIRED
  RENEWAL_DUE
}