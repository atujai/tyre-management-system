generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id          String    @id @default(cuid())
  email       String    @unique
  password    String
  name        String    @unique
  role        Role      @default(STAFF)
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  permissions Json?     @default("{\"tyres\": true, \"users\": false, \"history\": true, \"stepney\": true, \"vehicles\": true, \"allotment\": true, \"dashboard\": true, \"locations\": true}")
  history     History[]

  @@map("users")
}

model Make {
  id        String    @id @default(cuid())
  name      String    @unique
  createdAt DateTime  @default(now())
  vehicles  Vehicle[]

  @@map("makes")
}

model VehicleType {
  id        String    @id @default(cuid())
  name      String    @unique
  createdAt DateTime  @default(now())
  vehicles  Vehicle[]

  @@map("vehicle_types")
}

model Vehicle {
  id           String       @id @default(cuid())
  reg          String       @unique
  type         String
  model        String
  stepneySlots Int          @default(1)
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  makeId       String?
  typeId       String?
  axles        Axle[]
  history      History[]
  stepneys     Tyre[]       @relation("VehicleStepneys")
  tyres        Tyre[]
  make         Make?        @relation(fields: [makeId], references: [id])
  vehicleType  VehicleType? @relation(fields: [typeId], references: [id])

  @@map("vehicles")
}

model Axle {
  id        String  @id @default(cuid())
  vehicleId String
  tyreCount Int
  steering  Boolean @default(false)
  drive     Boolean @default(false)
  line      Int?
  sortOrder Int     @default(0)
  vehicle   Vehicle @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  tyres     Tyre[]

  @@map("axles")
}

model Tyre {
  id               String       @id @default(cuid())
  serial           String       @unique
  brand            String
  size             String
  pattern          String?
  purchaseDate     DateTime?
  initialTread     Float        @default(20)
  currentTread     Float        @default(20)
  status           TyreStatus   @default(INVENTORY)
  cost             Float?
  remarks          String?
  withRim          Boolean      @default(true)
  vehicleId        String?
  axleId           String?
  position         String?
  mountingDate     DateTime?
  stepneyVehicleId String?
  stepneyDate      DateTime?
  stepneyType      StepneyType?
  locationId       String?
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt
  history          History[]
  images           TyreImage[]
  axle             Axle?        @relation(fields: [axleId], references: [id])
  location         Location?    @relation(fields: [locationId], references: [id])
  stepneyVehicle   Vehicle?     @relation("VehicleStepneys", fields: [stepneyVehicleId], references: [id])
  vehicle          Vehicle?     @relation(fields: [vehicleId], references: [id])

  @@map("tyres")
}

model TyreImage {
  id        String    @id @default(cuid())
  tyreId    String
  url       String
  type      ImageType @default(TYRE)
  caption   String?
  createdAt DateTime  @default(now())
  tyre      Tyre      @relation(fields: [tyreId], references: [id], onDelete: Cascade)

  @@map("tyre_images")
}

model Location {
  id        String       @id @default(cuid())
  name      String
  type      LocationType
  address   String?
  contact   String?
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt
  tyres     Tyre[]

  @@map("locations")
}

model History {
  id        String   @id @default(cuid())
  date      DateTime @default(now())
  action    String
  details   String?
  tyreId    String
  vehicleId String?
  axleIndex Int?
  position  String?
  userId    String?
  createdAt DateTime @default(now())
  tyre      Tyre     @relation(fields: [tyreId], references: [id], onDelete: Cascade)
  user      User?    @relation(fields: [userId], references: [id])
  vehicle   Vehicle? @relation(fields: [vehicleId], references: [id])

  @@map("history")
}

enum Role {
  ADMIN
  STAFF
}

enum TyreStatus {
  MOUNTED
  INVENTORY
  STEPNEY
  WORN
  DAMAGED
  REPAIR
  SCRAPPED
}

enum StepneyType {
  READY
  BURST
  CLAIM
  PUNCTURE
  RETREAD_CHECKUP
}

enum LocationType {
  GODOWN
  RETREADER
}

enum ImageType {
  TYRE
  DOCUMENT
  SERIAL_NUMBER
}
